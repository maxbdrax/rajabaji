rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "rakibakonsdrax@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'role']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.balance is number &&
             data.role in ['admin', 'user'];
    }

    function isValidDeposit(data) {
      return data.keys().hasAll(['uid', 'amount', 'method', 'transactionId', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.method in ['bkash', 'nagad', 'rocket'] &&
             data.transactionId is string && data.transactionId.size() < 64 &&
             data.status == 'pending';
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['uid', 'amount', 'method', 'accountNumber', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.method in ['bkash', 'nagad', 'rocket'] &&
             data.accountNumber is string && data.accountNumber.size() < 32 &&
             data.status == 'pending';
    }

    function isValidBet(data) {
      return data.keys().hasAll(['uid', 'game', 'amount', 'winAmount', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.game in ['slots', 'aviator'] &&
             data.amount is number && data.amount > 0 &&
             data.winAmount is number &&
             data.status in ['win', 'loss'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user' && request.resource.data.balance == 0;
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.balance == resource.data.balance);
    }

    match /deposits/{depositId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDeposit(request.resource.data);
      allow update: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data);
      allow update: if isAdmin();
    }

    match /config/payments {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBet(request.resource.data);
      allow update: if false;
    }
  }
}
